[Unit]
Description=Chamo Node.js app
After=network.target mysql.service

[Service]
Type=simple
WorkingDirectory=/var/www/chamo
EnvironmentFile=/var/www/chamo/.env
ExecStart=/usr/bin/node /var/www/chamo/dist/index.js
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
